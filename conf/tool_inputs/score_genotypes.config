def genome_resources = params.genomes?.get(params.genome as String) ?: [:]
def clustering_tracks = (genome_resources.clustering_tracks ?: []) as List
def clustering_track_names = (genome_resources.clustering_track_names ?: []) as List

def trackByName = { name ->
    def idx = clustering_track_names.indexOf(name)
    idx >= 0 && idx < clustering_tracks.size() ? clustering_tracks[idx] : null
}

params.tool_inputs = params.tool_inputs ?: [:]
params.tool_inputs.score_genotypes = [
    "ScoreGenotypes.truth_json"                : params.score_genotypes_truth_json,
    "ScoreGenotypes.gq_recalibrator_model_file" : genome_resources.aou_recalibrate_gq_model_file,
    "ScoreGenotypes.recalibrate_gq_args"        : [
        "--keep-homvar false",
        "--keep-homref true",
        "--keep-multiallelic true",
        "--skip-genotype-filtering true",
        "--min-samples-to-estimate-allele-frequency -1"
    ],
    "ScoreGenotypes.genome_tracks"             : [
        trackByName("RM"),
        trackByName("SD"),
        trackByName("SR"),
        genome_resources.recalibrate_gq_genome_track_umap100,
        genome_resources.recalibrate_gq_genome_track_umap24
    ].findAll { it != null },
    "ScoreGenotypes.linux_docker"              : params.linux_docker,
    "ScoreGenotypes.gatk_docker"               : params.gatk_docker,
    "ScoreGenotypes.sv_base_mini_docker"       : params.sv_base_mini_docker,
    "ScoreGenotypes.sv_pipeline_docker"        : params.sv_pipeline_docker
]
