def genome_resources = params.genomes?.get(params.genome as String) ?: [:]

params.tool_inputs = params.tool_inputs ?: [:]
params.tool_inputs.gather_batch_evidence = [
    "GatherBatchEvidence.sv_base_mini_docker"                        : params.sv_base_mini_docker,
    "GatherBatchEvidence.sv_base_docker"                             : params.sv_base_docker,
    "GatherBatchEvidence.sv_pipeline_docker"                         : params.sv_pipeline_docker,
    "GatherBatchEvidence.sv_pipeline_qc_docker"                      : params.sv_pipeline_qc_docker,
    "GatherBatchEvidence.cnmops_docker"                              : params.cnmops_docker,
    "GatherBatchEvidence.linux_docker"                               : params.linux_docker,
    "GatherBatchEvidence.gatk_docker"                                : params.gatk_docker,
    "GatherBatchEvidence.cytoband"                                   : genome_resources.cytoband,
    "GatherBatchEvidence.mei_bed"                                    : genome_resources.mei_bed,
    "GatherBatchEvidence.cnmops_allo_file"                           : genome_resources.cnmops_allo_file,
    "GatherBatchEvidence.cnmops_exclude_list"                        : genome_resources.cnmops_exclude_list,
    "GatherBatchEvidence.cnmops_chrom_file"                          : genome_resources.cnmops_chrom_file,
    "GatherBatchEvidence.primary_contigs_fai"                        : genome_resources.primary_contigs_fai,
    "GatherBatchEvidence.genome_file"                                : genome_resources.genome_file,
    "GatherBatchEvidence.matrix_qc_distance"                         : params.gbe_matrix_qc_distance,
    "GatherBatchEvidence.min_svsize"                                 : params.gbe_min_svsize,
    "GatherBatchEvidence.run_matrix_qc"                              : params.gbe_run_matrix_qc,
    "GatherBatchEvidence.sd_locs_vcf"                                : genome_resources.sd_locs_vcf,
    "GatherBatchEvidence.ref_dict"                                   : genome_resources.reference_dict,
    "GatherBatchEvidence.ploidy_sample_psi_scale"                    : params.gbe_ploidy_sample_psi_scale,
    "GatherBatchEvidence.gcnv_learning_rate"                         : params.gbe_gcnv_learning_rate,
    "GatherBatchEvidence.gcnv_num_thermal_advi_iters"                : params.gbe_gcnv_num_thermal_advi_iters,
    "GatherBatchEvidence.gcnv_max_advi_iter_first_epoch"             : params.gbe_gcnv_max_advi_iter_first_epoch,
    "GatherBatchEvidence.gcnv_max_advi_iter_subsequent_epochs"       : params.gbe_gcnv_max_advi_iter_subsequent_epochs,
    "GatherBatchEvidence.gcnv_max_training_epochs"                   : params.gbe_gcnv_max_training_epochs,
    "GatherBatchEvidence.gcnv_min_training_epochs"                   : params.gbe_gcnv_min_training_epochs,
    "GatherBatchEvidence.gcnv_convergence_snr_averaging_window"      : params.gbe_gcnv_convergence_snr_averaging_window,
    "GatherBatchEvidence.gcnv_convergence_snr_countdown_window"      : params.gbe_gcnv_convergence_snr_countdown_window,
    "GatherBatchEvidence.gcnv_cnv_coherence_length"                  : params.gbe_gcnv_cnv_coherence_length,
    "GatherBatchEvidence.gcnv_copy_number_posterior_expectation_mode": params.gbe_gcnv_copy_number_posterior_expectation_mode,
    "GatherBatchEvidence.gcnv_log_emission_sampling_rounds"          : params.gbe_gcnv_log_emission_sampling_rounds,
    "GatherBatchEvidence.gcnv_p_alt"                                 : params.gbe_gcnv_p_alt,
    "GatherBatchEvidence.gcnv_sample_psi_scale"                      : params.gbe_gcnv_sample_psi_scale,
    "GatherBatchEvidence.ref_copy_number_autosomal_contigs"          : genome_resources.copy_number_autosomal_contigs,
    "GatherBatchEvidence.allosomal_contigs"                          : genome_resources.allosomal_contigs,
    "GatherBatchEvidence.gcnv_caller_internal_admixing_rate"         : params.gbe_gcnv_caller_internal_admixing_rate,
    "GatherBatchEvidence.gcnv_caller_update_convergence_threshold"   : params.gbe_gcnv_caller_update_convergence_threshold,
    "GatherBatchEvidence.gcnv_convergence_snr_trigger_threshold"     : params.gbe_gcnv_convergence_snr_trigger_threshold,
    "GatherBatchEvidence.gcnv_depth_correction_tau"                  : params.gbe_gcnv_depth_correction_tau,
    "GatherBatchEvidence.gcnv_log_emission_sampling_median_rel_error": params.gbe_gcnv_log_emission_sampling_median_rel_error,
    "GatherBatchEvidence.gcnv_qs_cutoff"                             : params.gbe_gcnv_qs_cutoff,
    "GatherBatchEvidence.run_ploidy"                                 : params.gbe_run_ploidy,
