process {
    withName: 'PICARD_COLLECTINSERTSIZEMETRICS' {
            ext.args = {
                def ref = params.genomes[params.genome]?.reference_fasta ?: params.genomes[params.genome]?.fasta
                ref ? "--REFERENCE_SEQUENCE ${ref}" : ''
            }
            publishDir = [
                mode: params.publish_dir_mode,
                path: { "${params.outdir}/InsertSize_out/${meta.id}" },
                pattern: "*.{txt,pdf}"
            ]
    }

    withName: 'BCFTOOLS_ANNOTATE' {
        ext.args   = '-Ov'
        ext.prefix = 'common_all_20180418_renamed'
    }

    withName: 'GATKSV_GATHERSAMPLEEVIDENCE' {
            publishDir = [
                mode: params.publish_dir_mode,
                path: { "${params.outdir}/GSE/" },
            ]
    }

    withName: 'GATKSV_EVIDENCEQC' {
            publishDir = [
                mode: params.publish_dir_mode,
                path: { "${params.outdir}/EVIDQC/" }
            ]
    }

    withName: 'SAMPLE_QC' {
            publishDir = [
                mode: params.publish_dir_mode,
                path: { "${params.outdir}/SAMPLEQC/${task.tag}" },
                pattern: "*.{tsv,pdf,ped}"
            ]
    }

    withName: 'BATCHING' {
            publishDir = [
                mode: params.publish_dir_mode,
                path: { "${params.outdir}/BATCHING/${task.tag}" }
            ]
    }

    withName: 'GATK_TRAINGCNV' {
            publishDir = [
                mode: params.publish_dir_mode,
                path: { "${params.outdir}/TRAINGCNV/" }
            ]
    }

    withName: 'GATKSV_GATHERBATCHEVIDENCE' {
            publishDir = [
                mode: params.publish_dir_mode,
                path: { "${params.outdir}/GBE/" }
            ]
    }

    withName: 'GATKSV_CLUSTERBATCH' {
            publishDir = [
                mode: params.publish_dir_mode,
                path: { "${params.outdir}/CLUSTERBATCH/" }
            ]
    }

    withName: 'GATKSV_GENERATEBATCHMETRICS' {
            publishDir = [
                mode: params.publish_dir_mode,
                path: { "${params.outdir}/GBM/" }
            ]
    }

    withName: 'GATKSV_FILTERBATCHSITES' {
            publishDir = [
                mode: params.publish_dir_mode,
                path: { "${params.outdir}/FILTERBATCHSITES/" }
            ]
    }

    withName: 'GATKSV_FILTERBATCHSAMPLES' {
            publishDir = [
                mode: params.publish_dir_mode,
                path: { "${params.outdir}/FILTERBATCHSAMPLES/" }
            ]
    }

    withName: 'GATKSV_MERGEBATCHSITES' {
            publishDir = [
                mode: params.publish_dir_mode,
                path: { "${params.outdir}/MERGEBATCHSITES/" }
            ]
    }

    withName: 'GATKSV_GENOTYPEBATCH' {
            publishDir = [
                mode: params.publish_dir_mode,
                path: { "${params.outdir}/GENOTYPEBATCH/" }
            ]
    }

    withName: 'GATKSV_REGENOTYPECNVS' {
            publishDir = [
                mode: params.publish_dir_mode,
                path: { "${params.outdir}/REGENOTYPECNVS/" }
            ]
    }

    withName: 'GATKSV_COMBINEBATCHES' {
            publishDir = [
                mode: params.publish_dir_mode,
                path: { "${params.outdir}/COMBINEBATCHES/" }
            ]
    }

    withName: 'GATKSV_RESOLVECOMPLEXVARIANTS' {
            publishDir = [
                mode: params.publish_dir_mode,
                path: { "${params.outdir}/RESOLVECOMPLEXVARIANTS/" }
            ]
    }

    withName: 'GATKSV_GENOTYPECOMPLEXVARIANTS' {
            publishDir = [
                mode: params.publish_dir_mode,
                path: { "${params.outdir}/GENOTYPECOMPLEXVARIANTS/" }
            ]
    }

    withName: 'GATKSV_CLEANVCF' {
            publishDir = [
                mode: params.publish_dir_mode,
                path: { "${params.outdir}/CLEANVCF/" }
            ]
    }

    withName: 'GATKSV_REFINECOMPLEXVARIANTS' {
            publishDir = [
                mode: params.publish_dir_mode,
                path: { "${params.outdir}/REFINECOMPLEXVARIANTS/" }
            ]
    }

    withName: 'GATKSV_JOINRAWCALLS' {
            publishDir = [
                mode: params.publish_dir_mode,
                path: { "${params.outdir}/JOINRAWCALLS/" }
            ]
    }

    withName: 'GATKSV_SVCONCORDANCE' {
            publishDir = [
                mode: params.publish_dir_mode,
                path: { "${params.outdir}/SVCONCORDANCE/" }
            ]
    }


    withName: 'GATKSV_SCOREGENOTYPES' {
            publishDir = [
                mode: params.publish_dir_mode,
                path: { "${params.outdir}/SCOREGENOTYPES/" }
            ]
    }


    withName: 'GATKSV_FILTERGENOTYPES' {
            publishDir = [
                mode: params.publish_dir_mode,
                path: { "${params.outdir}/FILTERGENOTYPES/" }
            ]
    }


    withName: 'GATKSV_ANNOTATEVCF' {
            publishDir = [
                mode: params.publish_dir_mode,
                path: { "${params.outdir}/ANNOTATEVCF/" }
            ]
    }
}
